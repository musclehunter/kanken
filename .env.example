# LLM API設定
# 語彙生成用（scripts/generate-vocab.js）
# 未設定の場合は LLM_API_KEY がフォールバックとして使われる
LLM_API_KEY_VOCAB=your-vocab-api-key-here

# 短文・問題生成用（今後 scripts/generate-questions.js）
# 語彙生成と別モデル・別アカウントを使いたい場合に設定
LLM_API_KEY_SENTENCE=your-sentence-api-key-here

# 日本語 meanings 生成用（scripts/generate-meanings-ja.js）
# 未設定の場合は LLM_API_KEY がフォールバックとして使われる
LLM_API_KEY_MEANINGS=your-meanings-api-key-here

# 共通設定
LLM_API_ENDPOINT=https://api.openai.com/v1/responses
#gpt-5.6-luna gpt-5.6-sol gpt-5.6-terra gpt-4o-mini
LLM_MODEL=gpt-5.6-luna

# 後方互換（どちらも未設定の場合のフォールバック）
LLM_API_KEY=your-api-key-here
