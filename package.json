{
  "name": "kanken-master",
  "version": "2.1.12",
  "description": "漢検マスター - 手書き採点対応の漢字検定対策PWAアプリ",
  "private": true,
  "scripts": {
    "build": "node build.js",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android",
    "cap:run": "npx cap run android",
    "android": "node build.js && npx cap sync && npx cap open android",
    "generate:vocab": "node scripts/generate-vocab.js",
    "generate:sentences": "node scripts/generate-sentences.js",
    "merge:sentences": "node scripts/merge-sentences.js",
    "generate:meanings-ja": "node scripts/generate-meanings-ja.js",
    "migrate:homophones": "node scripts/migrate-homophones.js",
    "admin": "node admin-server.js"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "dotenv": "^16.6.1",
    "typescript": "^6.0.3"
  }
}
